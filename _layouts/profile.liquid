---
layout: default
---
{% assign member = page %}

<!--- picture | name --->
<div class="row justify-content-sm-center">
    <div class="col-sm-3
                ">
        {% include figure.liquid 
        loading="eager" 
        path= page.picture
        class="img-fluid z-depth-1 rounded-circle" 
        zoomable=false %}
    </div>
    <div class="col-sm-8 ">
        <h1>{{ page.name }}</h1>
        <h5>{{ page.position }}</h5>
        <h6>{{ page.education[0] }}</h6>
    </div>
</div>
<!--- contact | miniBio --->
<div class="row justify-content-sm-center">
    <div class="col-sm-3">
        <div class="row center">
          {% if page.social %}
            {% include member_social_link.liquid %}
          {% endif %}
        </div>
        <div class="row center">
            <p>
                {% if page.location %}
                    {% include member_location.liquid %}
                {% endif %}
            </p>
           
        </div>
    </div>
    <div class="col-sm-8">
        <h3>miniBio</h3>
        {{ content }}
    </div>
</div>


<hr>
<div>
    {% include research-line-in-people.liquid %}
</div>

<hr>
<h4>Publications</h4>
<script src="/assets/js/tabs.js"></script>

{% tabs papers %}

{% tab papers Selected Papers %}

Algunos

{% endtab %}

{% tab papers All Papers %}

Todos

{% endtab %}

{% endtabs %}