   journal={International Journal of Hydrogen Energy},
   keywords={AB5alloy,Carbon nanospheres,Electrochemical capacity,Ni-MH batteries,Ni-doped},
   pages={14978-14982},
   publisher={Elsevier},
   title={Electrochemical effect of carbon nanospheres on an AB5alloy},
   volume={37},
   url={http://dx.doi.org/10.1016/j.ijhydene.2011.12.101},
   year={2012},
}
