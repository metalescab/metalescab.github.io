@article{Troiani1999,
   abstract={The phenomenological theories for martensitic transformation by Wechsler, Lieberman, Read and Bowles, Mackenzie describes well the crystallography and orientation relationship between austenite and martensite by postulating an undistorted habit plane. However, they do not give information on the actual path of the atomic displacements during the martensitic transformation. An atomistic model which attempts to do that and results in the same crystallography as in the phenomenological models has previously been described for the transformation from the bcc to the fcc structure by one of the authors. In this model the main shear occurs on the bcc (110)β <11̄0>β plane, to which a shuffle on an inclined plane is added. Because both steps could never be separated experimentally, the model remained speculative. It has now been possible to show that an intermediate structure which consists only of shears on (110)β <11̄0>β can be obtained by the dezincification of β phase Cu–Zn alloys in the form of coherent spherical particles with the 4H structure. Its appearance proves that this structure has a sufficiently low free energy to serve also as the first step in the martensitic transformation, in which its energy can be decreased further by the shuffles.},
   author={H.E Troiani and M Ahlers},
   doi={10.1016/S0921-5093(99)00370-6},
   issn={09215093},
   journal={Materials Science and Engineering: A},
   keywords={Dezincification,Martensite,Phase transformation},
   month={12},
   pages={200-203},
   title={The formation of an intermediate structure during the dezincification of β Cu–Zn alloys and its relevance for the martensitic transformation},
   volume={273-275},
   url={http://www.sciencedirect.com/science/article/pii/S0921509399003706 http://linkinghub.elsevier.com/retrieve/pii/S0921509399003706},
   year={1999},
}
@article{Damiani1999a,
   abstract={The influence of the absorption of hydrogen on the martensitic transformation of polycrystalline wires of a Ti-49.83at%Ni-0.08at%Cu alloy was studied using electrical resistivity. It was found that the stability of the austenite and the martensite is affected in the same way, resulting in no change of the transformation temperatures for H concentrations as high as 12 at%. No indication for hydrogen desorption was found below 423 K. Hydrogen has also been charged in single crystalline samples of three Cu-Zn-Al alloys at room temperature, presenting the β, 18R or 2H phases. The maximum concentration reached was around 0.04 at% and no influence was found on several properties of the martensitic transformation. © 1999 Elsevier Science S.A. All rights reserved.},
   author={C. Damiani and J.L. Pelegrina and M. Ahlers},
