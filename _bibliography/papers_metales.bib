   year={2002},
}
@article{Marinelli2002a,
   abstract={The lattice parameters (LPs) of the metastable face-centered cubic and hexagonal close-packed phases in Fe-Mn-Co system have been determined. The LP of the γ phase shows a striking behaviour, which is explained by invoking magnetic effect. The relative volume difference accompanying the martensitic transition is discussed. © 2002 Published by Elsevier Science Ltd. on behalf of Acta Materialia Inc.},
