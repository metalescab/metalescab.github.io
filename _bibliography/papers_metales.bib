   title={Temperature-induced transformations and martensitic reorientation processes in ultra-fine-grained Ni rich pseudoelastic NiTi wires studied by electrical resistance},
   volume={735},
   url={https://doi.org/10.1016/j.jallcom.2017.12.009 https://linkinghub.elsevier.com/retrieve/pii/S0925838817341841},
   year={2018},
}
