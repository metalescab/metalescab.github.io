   issn={0021-8979},
   issue={10},
   journal={Journal of Applied Physics},
   pages={104303},
   title={Evolution of the magnetic anisotropy with particle size in antiferromagnetic Cr2O3 nanoparticles},
   volume={108},
   url={http://aip.scitation.org/doi/10.1063/1.3506535},
