   journal={Physica B: Condensed Matter},
   keywords={AC susceptibility,Aerogel,Iron oxide,Nanoparticles},
   pages={229-234},
   title={Synthesis and magnetic properties of iron oxide-silica aerogel nanocomposites},
   volume={398},
   year={2007},
}
@article{Salva2007,
   abstract={We measured the anelastic spectra of LaMnO3. An internal friction peak appears at 300-350 K depending on the sample preparation. Two methods of preparation of the sample were used changing also the sintering time and temperature The IF peak disappears when the sample was sintered for 79 h at 1400 C. The grains show soldered. When the grains are not soldered an IF peak is obtained with its corresponding modulus drop. Applying the theory of grain-boundary sliding, proposed by C. Zener in 1941, the Poisson ratio χ=0.38(5) and 0.43(5) could be obtained. © 2006 Elsevier B.V. All rights reserved.},
   author={H. R. Salva and A. A. Ghilarducci and A. G. Leyva and S. S. Seiro},
