@article{Torra2012,
   abstract={The properties of SMA (Shape Memory Alloys, smart materials) are associated to a first order phase transition named martensitic transformation that occurs between metastable phases: austenite and martensite. At higher temperature phase or at lower stress the austenite is the metastable phase. The martensite appears at lower temperature phase or higher stresses. The hysteresis of the transformation permits different levels of applications, i.e., in their use as a damper. Two types of applications can be considered in damping of structures in Civil Engineering. The first one is related to diminishing the damage induced by earthquakes. The second one is a reduction of oscillation amplitude associate to an increase of the lifetime for the stayed cables in bridges. Different fundamental behavior of the SMA needs to be guaranteed in each case. © 2012 Trans Tech Publications, Switzerland.},
   author={Vicenç Torra and Carlota Auguet and Guillem Carreras and Lamine Dieng and Francisco C. Lovey and Patrick Terriault},
   doi={10.4028/www.scientific.net/MSF.706-709.2020},
   isbn={978-3-03785-303-0},
   issn={1662-9752},
   journal={Materials Science Forum},
   keywords={Damping,Martensitic Transformation (MT),NiTi,Shape Memory Alloy (SMA),Stayed Cables},
   pages={2020-2025},
   title={The SMA: An Effective Damper in Civil Engineering that Smoothes Oscillations},
   volume={706-709},
   url={http://www.scientific.net/MSF.706-709.2020},
   year={2012},
}
@article{Soul2012,
   abstract={A 1-D thermomechanical model aimed to represent the behavior of Ni-rich ultrafine grained NiTi wires upon pseudoelastic cycling was developed. The three more significant features associated to the pseudoelastic behavior of NiTi wires were taken into consideration for its formulation. These are: the localized character of the stress induced transformation which is accompanied by the nucleation and propagation of a discrete number of transformation fronts; the thermal effects associated with the heat of transformation and the Clausius-Clapeyron type of dependence of critical stresses with temperature; the functional fatigue effects resulting in the decrease of critical stresses and the accumulation of permanent deformation during cycling. The model assesses the mechanical response by evaluating the local conditions at the different moving interfaces that might be present at a certain time. It was implemented in MATLAB and numerical simulations have been found to exhibit good agreement with experimental results obtained under similar conditions. It is therefore considered that the model here proposed constitutes a good conceptualization of the complex pseudoelastic behavior of NiTi wires that allows reproducing the fundamental aspects of actual observed behaviors},
   author={H Soul and A Yawny},
   doi={10.1016/j.mspro.2012.06.019},
   issn={22118128},
   issue={0},
   journal={Procedia Materials Science},
   pages={141-148},
   title={Superelastic Behaviour of Niti Wires Under General Cycling Conditions: Thermomechanic 1-D Modelling},
   volume={1},
   url={http://www.sciencedirect.com/science/article/pii/S221181281200020X},
   year={2012},
}
@article{Bubani2012,
   abstract={The 18R. ↔. 6R martensite-martensite transformation in Cu-based alloys exhibits large hysteresis, large pseudoelastic strain and weak transformation stress dependence on temperature. However, concomitant plastic deformation taking place in the 6R phase inhibits the use of these properties for applications. A novel approach to minimizing or even suppressing 6R plastic deformation during the 18R-6R transformation in CuZnAl shape-memory alloy single crystals with electronic concentration . e/. a=. 1.48 is presented. The method is based on a thermal treatment that introduces nanoprecipitates in the alloy. Results suggest that the role of CuZnAl shape-memory alloys in engineering should be reconsidered, as many energy damping applications could benefit from the huge hysteresis associated with the 18R-6R transformation, once the 6R plastic deformation is suppressed. © 2012 Elsevier B.V..},
   author={Franco de Castro Bubani and Marcos Sade and Francisco Lovey},
   doi={10.1016/j.msea.2012.02.051},
   issn={09215093},
   journal={Materials Science and Engineering A},
   keywords={Martensitic transformation,Mechanical characterization,Phase transformation,Precipitation,Shape-memory alloys},
   pages={88-95},
   publisher={Elsevier B.V.},
   title={Improvements in the mechanical properties of the 18R↔6R high-hysteresis martensitic transformation by nanoprecipitates in CuZnAl alloys},
   volume={543},
   url={http://dx.doi.org/10.1016/j.msea.2012.02.051},
   year={2012},
}
@book{DeCastroValente2012,
   abstract={En este trabajo se fabrican aleaciones por una técnica de enfriamiento ultrarápido de chill-casting, con el objetivo de obtener un imán de estructura compleja parcialmente amorfa con propiedades magnéticas interesantes para aplicaciones multifuncionales. Se utilizan diversos métodos de caracterización microestructural a fín de poder describir aspectos que relacionen la estructura con propiedades magnéticas. Se diseña y construye un motor sincrónico donde el material magnético en estudio es fundamental para el funcionamiento del motor. También se proyecta un dispositivo “medidor de torque” para estimar la fuerza del motor y la eficiencia del imán. Los objetivos del presente trabajo son: a) estudiar la síntesis y la microestructura en un sistema nanocompuesto formado por elementos de tierra rara y metal de transición de una aleación Nd60Fe30Al10 de fácil amorfización; b) relacionar aspectos de la síntesis y la estructura con sus propiedades magnéticas y c) mensurar la eficiencia del imán que lo habilite para una aplicación de interés práctico.},
   author={R. de Castro Valente and A.A. Ghilarducci},
   isbn={9783848455225},
   pages={138},
   title={Desarrollo de imanes duros nanoestructurados. Diseño y Aplicaciones Multifuncionales},
   year={2012},
}
@article{Castelluccio2012,
   abstract={Currently, measuring the local tensile strength in inhomogeneous materials is not standardised, nor accepted techniques are available despite such technique would be beneficial in a variety of technological applications. Thus, this work introduces an innovative method for assessing stress–strain properties at a sub-millimeter scale and illustrates the potential of the technique by evaluating the strength of a sub- region in the HAZ from welded steels pipes. The method employs a fully instrumented stage inside a scanning electron microscope that stretches small tensile specimens (2.0 mm · 0.5 mm cross-section, 12.5 mm gage length) while registering detailed images of the deformed region. The specimens, cut from full-scale welds, include in their gage length weld metal, base metal and HAZ and have an 85 lm period grid of evaporated lead on their surface to visualise the deformation. Upon straining, local strain is determined by correlating sequential images of the specimen surface with an open source code for particle image velocimetry. The calculated local strain within the HAZ and the load values recorded during testing are converted into a local stress–strain response. The results for two different heat inputs agree with usual, but indirect and less accurate assessments procedures, including local hardness measurements and notched bar testing. KEY},
   author={G. M. Castelluccio and A. A. Yawny and J. E. Perez Ipiña and H. A. Ernst},
   doi={10.1111/j.1475-1305.2010.00799.x},
   issn={00392103},
   issue={1},
   journal={Strain},
   keywords={HAZ,image correlation,in situ test,inhomogeneity,particle image velocimetry,steel pipe,tensile behaviour,weld small specimens},
   pages={68-74},
   title={In situ evaluation of tensile properties of heat-affected zones from welded steel pipes},
   volume={48},
   year={2012},
}
@article{Cuscueta2012,
   abstract={In this paper, the effect of the addition of carbon nanospheres (CNE) by high energy mechanical milling to the active material of the negative electrode of a Nickel-Metal Hydride (Ni-MH) battery is studied. The hydrogen storage alloy (MH) is an AB5-type (Lm0.95Ni3.8Co0.3Mn0.3Al0.4), where Lm is a mixture of rare earths, and it was prepared by melting the constituent elements in an electric induction furnace. The CNE were synthesized by two-stage polymerization of furfuryl alcohol, drying and carbonization, and were subsequently doped with different proportions of Ni (0-20%) by the method of wet impregnation with Nickel nitrate hexahydrate. The behavior of electrochemical cells consisting of a working electrode with 45% of MH, 5% of CNE pure and doped with different proportions of Ni and 50% carbon Teflon acting as electrical and mechanical support, a counter electrode of Ni mesh, and a reference electrode Hg/HgO was studied. The experiments covered electrochemical activation and cycle stability, rate capability and electrochemical impedance spectroscopy. The results show that the addition of CNE improves the electrochemical performance, and particularly the CNEs pure and doped with 20% of Ni present the best electrochemical performance in discharge capacity, rate capability and impedance spectroscopy. © 2012, Hydrogen Energy Publications, LLC. Published by Elsevier Ltd. All rights reserved.},
   author={D. J. Cuscueta and H. L. Corso and A. Arenillas and P. S. Martinez and A. A. Ghilarducci and H. R. Salva},
   doi={10.1016/j.ijhydene.2011.12.101},
