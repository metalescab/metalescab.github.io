   year={2006},
}
@article{Tagliazucchi2006,
   abstract={A new route to obtain metal oxide nanotubes is presented: an inorganic coordination complex precursor containing the metal ions and impregnated into alumina membrane templates yield hollow tubular nanostructures of LaNiO3by calcination at 600 °C as characterized by powder X-ray diffraction (XRD). Scanning electron microscopy (SEM) shows that the resulting nanotubes have 200 nm in diameter in good agreement with the template pore. Transmission electron microscopy (TEM) and dark field transmission electron microscopy (DF-TEM) show that the nanotubes with 10-20 nm walls and internal separations are composed of 3-5 nm crystals. © 2005 Elsevier Ltd. All rights reserved.},
   author={Mario Tagliazucchi and Rodolfo D. Sanchez and Horacio E. Troiani and Ernesto J. Calvo},
