   year={1991},
}
@article{Aligia1992,
   abstract={We have calculated several thermodynamic properties of a lattice gas mode with screened Coulomb repulsions V1 for ith nearest neighbors up to i=5, but for second-nearest neighbors with a Cu in between the repulsion V2Cu is reduced by charge transfer effects (V2Cu=ƒV2, ƒ <). We used the 3 × 3 point approximation of the cluster-variation method (CVM). The composition (x)- temperature (T) phase diagram for V3=V4=V5= 0, V1=+∞ and ƒ=-1, is similar to the one published by other authors. Taking instead ƒ∼0 and all Vi≠0, the low-T, low-x phase disappears from the phase diagram and structures that explain the experimentally observed diffraction patterns appear; the tetragonal-orthorhombic II transition becomes continuous and displaces to lower temperatures. We also explain the structure in the derivative of x with respect to the chemical potential (μ) observed experimentally in the tetragonal phase.},
   author={A.A. Aligia and J. Garcés},
   doi={10.1016/0921-4534(92)90695-9},
   issn={0921-4534},
   issue={1-2},
   journal={Physica C: Superconductivity},
   month={5},
   pages={223-234},
   publisher={North-Holland},
   title={Thermodynamics of O ordering in YBa2Cu3O6+x: Effect of Coulomb repulsion},
   volume={194},
   url={https://www.sciencedirect.com/science/article/pii/0921453492906959},
   year={1992},
}
@article{Guillermet1992,
   abstract={We make an extensive study of cohesive properties such as the enthalpy of formation Δ0H and the standard vibrational entropy 0S at 298.15 K of metal carbides MeC, Me3C2 Me2C, Me7C3, Me5C2, Me3C and Me23C6, with Me being a 3d-transition metal, Sc, Ti, V, Cr, Mn, Fe, Co and Ni. Direct and indirect experimental information is used. For systems where experimental data are lacking, we rely on interpolation and extrapolation procedures, assuming that the bonding properties vary smoothly as a function of the average number of valence electrons per atom in the compound, ne,. In 0S the atomic masses enter in such a way that they can be taken into consideration exactly, and only an appropriate averaged interatomic force constant ks needs to be estimated. The systematic variations with ne were previously noted by us in 3rd-transition metal carbides and nitrides (Fernández Guillermet and Grimvall, Phys. Rev. B40, 10,582 (1989)), and can be theoretically understood through an electron-band filling argument. That approach is considerably extended in the present work. Many of the compounds studied are metastable, i.e. the phase does not appear in the stable metal-carbon phase diagram. This fact is used as important indirect information which, together with our estimated entropy, gives limits to Δ0H of metastable carbides through CALPHAD calculations of phase diagrams. Our results are summarized in tables of the room-temperature enthalpy of formation Δ0H, the entropy Debye temperature θs, the corresponding average interatomic force constant ks and the standard vibrational entropy 0S(298.15). Δ0H is in good general agreement with predictions from Miedema's formula, with some small but significant differences. The general plcture of the cohesion in the carbides suggests important p−d bonding for Sc, Ti and V compounds, with a maximum strength for TiC, and weaker and more metallic bonding in Cr, Mn, Fe, Co and Ni carbides.},
   author={Armando Fernández Guillermet and Göran Grimvall},
   doi={10.1016/0022-3697(92)90019-A},
   issn={0022-3697},
   issue={1},
   journal={Journal of Physics and Chemistry of Solids},
   month={1},
   pages={105-125},
   publisher={Pergamon},
   title={Cohesive properties and vibrational entropy of 3d-transition metal carbides},
   volume={53},
   url={https://www.sciencedirect.com/science/article/pii/002236979290019A},
   year={1992},
}
@article{Lovey1992,
   abstract={A detailed study of the characteristics of the hysteresis loops in stress induced transformations was carried out using a high resolution apparatus. Samples with two different thermal treatments, air cooled and water quenched from 1070 K, were tested. The contribution of the nucleation processes to the hysteretic behaviour was evaluated. It was found that the intrinsic pseudoelasticity, due to the interaction of the martensite with the dislocations, plays a crucial role in the phenomenology of the transformation. This interaction prevents the growth of a unique plate and the transformation proceeds by successive nucleation of new plates. The friction associated to the movement of a single interface was also measured. From the experiments the relevant parameters which determine the hysteretic behaviour were identified. The hysteresis loops were computer simulated on the base of these parameters. The results showed a good agreement with the experimental observations. On effectue une étude détaillée des caractéristique des cycles d'hystérésis des transformations induites par la contrainte en utilisant un appareillage à haute résolution. Des échantillons ayant subi deux traitements thermiques différents, refroidis à l'air et trempés depuis 1070 K, sont testés. La contribution des mécanismes de germination à l'hystérésis est évaluée. On trouve que la pseudo-élasticité intrinsèque, due à l'interaction de la martensite avec les dislocations, joue un rôle crucial dans la phénoménologie de la transformation. Cette interaction empêche la croissance d'une plaquette unique et la transformation se produit par la germination successive de nouvelles plaquettes. Le frottement associé au mouvement d'une seule interface est mesuré aussi. A partir de ces expériences, les paramètres significatifs qui déterminent l'hystérésis sont identifiés. Les boucles d'hystérésis sont simulées sur ordinateur en se basant sur ces paramètres. Les résultats montrent un bon accord avec les observations expérimentales. Die Merkmale der Hystereseschleifen bei spannungsinduzierten Umwandlungen werden mit einem hochauflösenden Apparat ausführlich studiert. Proben mit zwei unterschiedlichen Wärmegeschichten, wasser- und luftabgeschreckt von 1070 K, werden untersucht. Der Beitrag der Keimbildungsprozesse zum Hystereseverhalten wird ausgewertet. Es ergibt sich, daβ die intrinsische Pseudoelastizität, herrührend von der Wechselwirkung des Martensits mit den Versetzungen, eine kritische Rolle in der Phänomenologie der Umwandlung spielt. Diese Wechselwirkung verhindert das Wachstum einer einheitlichen Platte, d.h die Umwandlung läuft über die aufeinanderfolgende Bildung von neuen Platten ab. Die mit der Bewegung einer einzelnen Grenzfläche zusammenhängende Reibung wird zusätzlich gemessen. Aus den Experimenten werden die für das Hystereseverhalten wichtigen Parameter abgeleitet. Die Hystereseschleifen werden anhand dieser Parameter mit dem Rechner simuliert. Die Ergebnisse stimmen mit den experimentellen Beobachtungen gut überein.},
   author={F.C. Lovey and A. Isalgue and V. Torra},
   doi={10.1016/0956-7151(92)90052-G},
   issn={0956-7151},
   issue={12},
   journal={Acta Metallurgica et Materialia},
   month={12},
   pages={3389-3394},
   publisher={Pergamon},
   title={Hysteresis loops in stress induced β-18R martensite transformation in CuZnAl},
   volume={40},
   url={https://www.sciencedirect.com/science/article/pii/095671519290052G},
   year={1992},
}
