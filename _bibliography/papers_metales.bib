@article{Haglund1993,
   abstract={This paper deals with the bonding properties of 3d-, 4d-, and 5d-transition-metal carbides and nitrides. We consider NaCl-structure compounds, MC and MN, as well as carbides and nitrides with more complex crystal structures. The enthalpies of formation at zero temperature Δ0H(0) of the MC and MN compounds are taken from previous ab initio linear-muffin-tin-oribtals calculations. We describe the structure as formed by a metal fcc lattice in which nonmetal atoms have been inserted at interstitial positions. Δ0H(0) is divided into contributions from (i) formation of metallic fcc lattice, (ii) expansion of this lattice to the lattice spacing of the compound, and (iii) insertion of nonmetal atoms into the metal lattice. Δ0H(0), plotted versus the position of M in the d series, shows a pronounced maximum for the Ti, Zr, and Hf carbides. In agreement with other work, we interpret this as due to the filling of bonding p-d hybridized states. The maximum in Δ0H(0) is followed first by a decrease and then by an almost constant value. We interpret this as an effect of a gradual population of antibonding and nonbonding electronic states. Size effects, i.e., contribution (ii), are small for the 4d- and 5d-series compounds. Δ0H(0) of MN is similar to that of MC, but the largest values occur for M=Sc,Y,La since N has one more valence electron than C. Bonding in the complex carbides and nitrides is given an analogous interpretation.},
   author={J. Häglund and A. Fernández Guillermet and G. Grimvall and M. Körling},
   doi={10.1103/PhysRevB.48.11685},
   isbn={0163-1829},
   issn={0163-1829},
   issue={16},
   journal={Physical Review B},
   month={10},
   pages={11685-11691},
   pmid={10007503},
   title={Theory of bonding in transition-metal carbides and nitrides},
   volume={48},
   url={https://link.aps.org/doi/10.1103/PhysRevB.48.11685},
   year={1993},
}
@article{Tolley1993,
   abstract={Low dose reactor neutron and 2.65 MeV electron irradiations have been carried out in the β and 18R phases of Cu-Zn-Al alloys, which are related by a martensitic transformation. At room temperature or above, irradiation with neutrons or electrons in the β-phase produced no changes in the β → 18R transformation temperature. However, irradiation in the 18R phase shifted the 18R → β transformation temperature towards higher values. The shift in the transformation temperature increased by irradiating to a higher dose or at a higher temperature. Electron irradiation at 124 K in the β-phase again produced no changes in the β → 18R transformation temperature. Electron irradiation at 95 K in several 18R samples with transformation temperatures of 173, 238, 263 and 350 K produced no changes in the 18R → β transformation temperature except for those samples with a transformation temperature of 350 K in which a shift towards higher temperature occurred. The changes in the 18R → β transformation temperature were found to be due to the stabilization of the 18R phase with respect to the β-phase by radiation enhanced diffusion. The kinetics of the stabilization by irradiation is discussed with a simple model for radiation enhanced diffusion.},
   author={A. Tolley and M. Ahlers},
   doi={10.1016/0022-3115(93)90098-J},
   issn={0022-3115},
   journal={Journal of Nuclear Materials},
   month={10},
   pages={339-343},
   publisher={North-Holland},
