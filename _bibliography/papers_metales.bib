   month={9},
   pages={183-188},
   publisher={Pergamon},
   title={Origin of the anomalous elastic spectrum in (TaSe4)2I},
   volume={108},
   url={https://www.sciencedirect.com/science/article/pii/S0038109898003123 http://linkinghub.elsevier.com/retrieve/pii/S0038109898003123},
   year={1998},
}
