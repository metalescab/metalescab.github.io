   keywords={Fatigue test methods,Martensitic transformations,Pseudoelasticity,Shape memory alloys},
   month={11},
   pages={300-305},
   publisher={Elsevier},
   title={A novel experimental method to assess the fatigue behavior of pseudoelastic NiTi wires},
   volume={116},
   url={https://doi.org/10.1016/j.ijfatigue.2018.06.034 https://linkinghub.elsevier.com/retrieve/pii/S0142112318302688},
   year={2018},
}
