   keywords={EPR,Magnetic properties of nanostructures,Nanocomposite,TEM,Vanadium oxide nanotube},
   pages={268-271},
   title={Iron oxide nanoparticles and VOx/Hexadecylamine nanotubes composite},
   volume={320},
   year={2008},
}
