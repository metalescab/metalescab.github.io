   pages={212-215},
   title={Synthesis of lanthanum nickelate perovskite nanotubes by using a template-inorganic precursor},
   volume={137},
   year={2006},
}
@article{ArneodoLarochette2006,
   abstract={The relative stability of the martensitic phases in Cu-Zn-Al shape memory alloys was used to evaluate the high-temperature equilibrium between the face-centered cubic and disordered hexagonal phases in a set of binary Hume-Rothery compounds. The equilibrium was found to be around an electron concentration of 1.44 in agreement with the available experimental binary phase diagrams. In the calculation, the contribution arising from the distortion of the martensitic structure due to long-range order was considered. It was additionally rationalized that, although the 18R phase is a common martensitic structure, it is not observed in the disordered state. © 2006 Elsevier B.V. All rights reserved.},
   author={P. Arneodo Larochette and A. M. Condó and J. L. Pelegrina and M. Ahlers},
   doi={10.1016/j.msea.2006.05.023},
   isbn={0921-5093},
   issn={09215093},
   issue={SPEC. ISS.},
   journal={Materials Science and Engineering A},
   keywords={Hume-Rothery alloys,Long-range order,Phase stability},
   pages={747-750},
   title={On the stability of the martensitic phases in Cu-Zn-Al, and its relationship with the equilibrium phases},
   volume={438-440},
   year={2006},
}
@article{Serrano2006,
   abstract={The microstructure of a quenched β phase Cu-Zn-Al-Ni alloy has been analysed by transmission electron microscopy. Different types of dislocations were observed, which seemed to be the main vacancy sinks. They are present as single dislocations, loops and helical dislocations. The latter had axes perpendicular to the Burgers vector, spreading around an angle of 30° from the nearest 〈1 0 0〉 direction. No γ precipitates were observed in this Ni-containing alloy, in sharp contrast to that in Cu-Zn-Al of similar electron concentration. The reason for this difference is examined, and the consequences of the presence of Ni on the ageing behaviour of the alloy are discussed. © 2006 Elsevier B.V. All rights reserved.},
   author={G. D. Serrano and J. L. Pelegrina and A. M. Condó and M. Ahlers},
   doi={10.1016/j.msea.2006.06.040},
   isbn={0921-5093},
   issn={09215093},
   issue={1-2},
   journal={Materials Science and Engineering A},
   keywords={Diffusion,Dislocations,Ordered alloys,Shape memory alloys,Vacancies},
   pages={149-154},
   title={Helical dislocations as vacancy sinks in β phase Cu-Zn-Al-Ni alloys},
   volume={433},
   year={2006},
}
@article{Gastien2006,
   abstract={An effect of inhibition of the γ′ martensitic structure in thermal and pseudoelastic β ↔ β′ + γ′ cycling in CuAlNi single crystals was reported previously [Gastien R, Corbellani CE, Álvarez Villar HN, Sade M, Lovey FC. Mater Sci Eng A 2003;349:191], and an experiment to determine the new thermodynamic parameters to obtain the stress-induced γ′ structure was performed [Gastien R, Corbellani CE, Sade M, Lovey FC. Acta Mater 2005;53:1685]. In this paper, a thermodynamic analysis of this effect using σ-T diagrams is proposed, in order to obtain a proper estimation of the energy involved in the inhibition process for pseudoelastic β ↔ β′ + γ′ cycling. © 2006 Acta Materialia Inc. Published by Elsevier Ltd. All rights reserved.},
   author={R. Gastien and C. E. Corbellani and M. Sade and F. C. Lovey},
   doi={10.1016/j.scriptamat.2005.12.055},
   issn={13596462},
   issue={8},
   journal={Scripta Materialia},
   keywords={Copper alloys,Martensitic phase transformations,Mechanical cycling,Shape memory alloys (SMA)},
   pages={1451-1455},
   title={A σ-T diagram analysis regarding the γ′ inhibition in β ↔ β′ + γ′ cycling in CuAlNi single crystals},
   volume={54},
   year={2006},
}
@article{Michutta2006,
   abstract={The present study shows that multiple-step martensitic transformations can be observed in aged Ni-rich NiTi single crystals. Ageing of solution-annealed and water-quenched Ni-rich NiTi single crystals results in a homogeneous precipitation of coherent Ni4Ti3particles. When the interparticle spacing reaches a critical value (order of magnitude: 200 nm), three distinct transformation processes are observed on cooling from the high-temperature phase using differential scanning calorimetry and in situ transmission electron microscopy. The transformation sequence begins with the formation of R-phase starting from all precipitate/matrix interfaces (first step). The transformation continues with the formation of B19′ and its subsequent growth along all precipitate/matrix interfaces (second step). Finally, the matrix in between the precipitates transforms to B19′ (third step). Elementary transformation mechanisms which account for two- and three-step transformations in a system with small-scale microstructural heterogeneities were identified. © 2006 Acta Materialia Inc.},
   author={J. Michutta and Ch Somsen and A. Yawny and A. Dlouhy and G. Eggeler},
   doi={10.1016/j.actamat.2006.03.036},
   isbn={1359-6454},
   issn={13596454},
   issue={13},
   journal={Acta Materialia},
   keywords={Differential scanning calorimetry,In situ cooling transmission electron microscopy,Multiple-step martensitic transformations,Ni-rich NiTi shape memory single crystals},
   pages={3525-3542},
   title={Elementary martensitic transformation processes in Ni-rich NiTi single crystals with Ni4Ti3 precipitates},
   volume={54},
   year={2006},
}
@article{Tolley2006,
   abstract={A study on the microstructures developed during artificial aging of the 2024 alloy in nondeformed and 8% pre-deformed specimens is presented. The microstructural characterization was carried out using transmission electron microscopy (TEM), specifically, diffraction contrast and high-resolution imaging. The S phase was found to precipitate heterogeneously on dislocations in both nondeformed and pre-deformed alloys. After the same artificial aging time, a larger density of S phase precipitates was obtained in the pre-deformed specimens. In non-deformed specimens, a high density of small nanometer-sized aggregates was found, that was absent in the pre-deformed specimens, that were identified as GP zones. To further analyze the small sized aggregates, artificially aged specimens with no previous deformation were also studied with Coincidence Doppler Broadening (CDB) of positron annihilation radiation. With this technique, information on the chemical environment around vacancy sites contained in the GP zones was obtained. Specifically, a composition close to (AlCu)2Mg was derived.},
   author={Alfredo Tolley and Rafael Ferragut and Alberto Somoza},
   doi={10.4028/www.scientific.net/MSF.519-521.489},
   isbn={9780878494088},
   issn={1662-9752},
   journal={Materials Science Forum},
   keywords={a study on the,abstract,age-hardenable alloys,aging of the 2024,alloy in non-,annihilation spectroscopy,deformed and 8,microstructures developed during artificial,positron,pre-deformed specimens is presented,precipitation,the microstructural characterization was,transmission electron microscopy},
   pages={489-494},
   title={Study of the Nanostructures Formed in 2024 Alloy during Thermomechanical Treatments},
   volume={519-521},
   url={http://www.scientific.net/MSF.519-521.489},
   year={2006},
}
