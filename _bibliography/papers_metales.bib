@article{Lovey1990,
   abstract={The characteristics of martensitic transformations can be greatly influenced by the presence of second-phase precipitates in the matrix. The interaction of the martensite with the precipitates depends strongly on the precipitate features. The microstructural characteristics of γ precipitates in the β matrix in a CuZnAl alloy is studied in this work. The analysis is performed by transmission electron microscopy and results concerning the precipitate morphology, size, distribution and degree of coherency are reported. The kinetics of the precipitate growth follow the Ostwald ripening mechanism and the largest precipitates are semi-coherent encircled by <100> edge-type dislocation loops.},
   author={F.C. Lovey and E. Cesari},
   doi={10.1016/0921-5093(90)90351-3},
   issn={0921-5093},
   issue={1},
   journal={Materials Science and Engineering: A},
   month={10},
   pages={127-133},
   publisher={Elsevier},
