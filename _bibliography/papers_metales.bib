@article{L.DelaeyT.Sugimotot1978,
   abstract={In the search for shape memory alloys with transformation temperatures above 373K, special attention is given to Cu-AI-Ni-Mn-Ti alloys, also called CANTiM. In the proper composition range these alloys show a/3-/~', thermoelastic martensitic transformation. The addition of Ti (in the order of 1 wt%) creates (Cu,Ni)~TL4I precipitates which hinder grain growth during annealing. The influence of those precipitates on the martenski~ transformation characteristics such as variant accommodation, hysteresis and transfo:mation temperatures is the subject of an important part of the research and development of the above-mentioned alloys. This paper communicates on changes in the stacking sequence of /31' martensite plates close to such precipitates. Several ~ variants show a progressively increasing stacking fault density upon approaching the precipitate surface, resulting in a hexagonal type of/~'~ martensite. Whether this effect is related to quenching stresses, matrix composition depletion around the precipitates or a special kind of variant accommodation due to the interaction between the precipitates will not be part of the discussion.},
   author={G. Barceló and R. Rapacioli and M. Ahlers},
   doi={10.1016/0036-9748(78)90076-5},
   issn={00369748},
   issue={12},
   journal={Scripta Metallurgica},
