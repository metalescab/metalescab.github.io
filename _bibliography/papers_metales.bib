@article{Arab1988a,
   abstract={The stabilization and subsequent recovery of stress induced martensite in CuZnAl single crystals has been quantitatively studied as a function of stabilization time and temperature, quenching temperature and previous aging in the β phase. It is observed that the stabilization reaches a saturation value for long stabilization times. It is shown that the results can be quantitatively interpreted considering that the degree of long range order inherited from the β phase during the martensitic transformation changes during the stabilization to a new equilibrium state. Nous avons étudié quantitativement la stabilisation et la restauration ultérieure de la martensite induite par contrainte dans des monocristaux de CuZnAl, en fonction du temps et de la température de stabilisation, de la température de trempe et du vieillissement antérieur dans la phase β. La stabilisation atteint une valeur de saturation pour les temps élevés de stabilisation. Nous montrons que les résultats peuvent être interprétés quantitativement en considérant que le degré d'ordre à grande distance—hérité de la phase β pendant la transformation martensitique—évolue pendant la stabilisation vers un nouvel état d'équilibre. Die Stabilisierung und die anschliessende Erholung von spannungsinduziertem Martensit in CuZnAl Einkristallen wurde in Abhängigkeit von der Stabilisierungszeit und- temperatur, Abschrecktemperatur und vorhergehender Alterungsbehandlung in der β Phase quantitativ untersucht. Es wird beobachtet, dass die Stabilisierung nach langen Zeiten einen Sättingungswert erreicht. Es wird gezeigt, dass die Stabilisierung quantitativ beschrieben werden kann mit der Annahme, dass der Fernordnungsgrad, den der Martensit von der β-Phase erbt, sich während der Stabilisierung zu einem neuen Gleichgewichtsgrad ändert.},
   author={A.Abu Arab and M. Ahlers},
   doi={10.1016/0001-6160(88)90207-6},
   issn={0001-6160},
   issue={9},
   journal={Acta Metallurgica},
   month={9},
   pages={2627-2638},
   publisher={Pergamon},
   title={The stabilization of martensite in CuZnAl alloys},
   volume={36},
   url={https://www.sciencedirect.com/science/article/pii/0001616088902076},
   year={1988},
}
