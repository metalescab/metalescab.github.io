@article{Guillermet1991,
   abstract={Using recent and accurate experimental information on various thermodynamic quantities up to the melting temperature Tf of molybdenum and tungsten, we make a detailed study of some of their high-temperature properties. In particular, we consider the entropy, reduced to a fixed crystal volume, and interpret the result in terms of an electronic part and a temperature-dependent entropy Debye temperature. The analysis reveals large explicit anharmonic effects. When plotted versus the reduced temperature T/Tf, various quantities of Mo and W related to anharmonicity show a striking similarity. For instance, the heat capacity CP is the same for Mo and W, to better than 1%, for T/Tf>0.2. We also make a detailed study of the temperature dependence of the Grüneisen parameter at constant pressure and at constant volume.},
   author={A. F. Guillermet and G. Grimvall},
   doi={10.1103/PhysRevB.44.4332},
   issn={0163-1829},
   issue={9},
   journal={Physical Review B},
   pages={4332-4340},
   title={Analysis of thermodynamic properties of molybdenum and tungsten at high temperatures},
