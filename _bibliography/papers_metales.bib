@article{Pelegrina2014,
   abstract={The order-disorder and order-order phase transition temperatures in the austenitic phase of Cu-based shape memory alloys were used to obtain a set of first- and second-neighbour pair interchange energies. To this end, a mean field model was postulated. Then, the applicability to different alloys of this simple model was analysed. It was found that a good agreement with the experimental phase diagram is obtained for Cu-Zn-Al, Cu-Al-Ni and Cu-Al-Be alloys using composition-independent parameters. It was also found that for Cu-Al-Mn alloys, composition-dependent pair interchange energies need to be employed. © 2014 Taylor & Francis.},
   author={J. L. Pelegrina},
   doi={10.1080/14786435.2014.927600},
   issn={14786443},
   issue={24},
   journal={Philosophical Magazine},
   keywords={shape memory alloys},
   pages={2705-2723},
   title={A simple model to predict long-range atomic ordering temperatures in Cu-based shape memory alloys},
   volume={94},
   year={2014},
}
@article{Lima2013,
   abstract={The role of agglomeration and magnetic interparticle interactions in heat generation of magnetic\r ferrofluids in an ac magnetic field is still unclear, with apparent discrepancy between the results\r presented in the literature. In this work, we measured the heat generating capability of\r agglomerated ferrite nanoparticles in a non-invasive ac magnetic field with f = 100 kHz and H 0\r  = 13 kA m −1 . The nanoparticles were morphologically and magnetically characterized, and the\r specific absorption rate (SAR) for our ac magnetic field presents a clear dependence on the diameter\r of the nanoparticles, with a maximum SAR = 48 W g −1 for 15 nm. Our agglomerated nanoparticles have\r large hydrodynamic diameters, thus the mechanical relaxation can be neglected as a heat generation\r mechanism. Therefore, we present a model that simulates the SAR dependence of the agglomerated\r samples on the diameter of the nanoparticles based on the hysteresis losses that is valid for the\r non-linear region (with H 0 comparable to the anisotropy field). Our model takes into account the\r magnetic interactions among the nanoparticles in the agglomerate. For comparison, we also measured\r the SAR of non-agglomerated nanoparticles in a similar diameter range, in which Néel and Brown\r relaxations dominate the heat generation.},
   author={E. Lima and E. De Biasi and M. Vasquez Mansilla and M. E. Saleta and M. Granada and H. E. Troiani and F. B. Effenberger and L. M. Rossi and H. R. Rechenberg and R. D. Zysler},
   doi={10.1088/0022-3727/46/4/045002},
   isbn={0006-2960 (Print)\r0006-2960 (Linking)},
   issn={00223727},
   issue={4},
   journal={Journal of Physics D: Applied Physics},
   pmid={16430213},
   title={Heat generation in agglomerated ferrite nanoparticles in an alternating magnetic field},
   volume={46},
   year={2013},
}
@article{Zysler2013,
   abstract={We propose a new method for determining the quantity of superparamagnetic iron oxide nanoparticles (Fe3O4, SPIONs) embedded in animal tissue using magnetization measurements. With this method, the smallest detectable quantity of magnetite nanoparticles in a tissue sample is -1 microg. We showed that this method has proved being efficient. In this study, we focused in determining the quantity of SPION confined in lung and liver tissue of mice injected with -13 nm magnetite superparamagnetic nanoparticles. Furthermore, the method allowed us to detect the magnetite nanoparticles present in animal tissues without letting the natural iron ions present in the tissue or blood interfere with the measurements.},
   author={R. D. Zysler and E. Lima and M. Vasquez Mansilla and H. E. Troiani and M. L.Mojica Pisciotti and P. Gurman and A. Lamagna and L. Colombo},
   doi={10.1166/jbn.2013.1467},
   isbn={1550-7033 (Print)\r1550-7033 (Linking)},
   issn={15507033},
   issue={1},
   journal={Journal of Biomedical Nanotechnology},
   keywords={Magnetic Nanoparticles,SPIONs Quantification,Superparamagnetism},
   pages={142-145},
   pmid={23627077},
   title={A new quantitative method to determine the uptake of SPIONs in animal tissue and its application to determine the quantity of nanoparticles in the liver and lung of Balb-c mice exposed to the SPIONs},
   volume={9},
   year={2013},
}
@article{Zelaya2013,
   abstract={Low energy mechanical alloying of Ni-35 at.%Al and Ni-40 at.%Al material was performed and the resulting structures were investigated by XRD and TEM. The final intermetallics observed consist of two phases, NiAl(B2) and Ni3Al while 7R and 3R martensite was observed in post-annealed samples. Different integrated milling times were associated to the intermetallic consolidation and initial blend dissociation. © 2013 The Society of Powder Technology Japan. Published by Elsevier B.V. and The Society of Powder Technology Japan. All rights reserved.},
   author={E. Zelaya and M. R. Esquivel and D. Schryvers},
   doi={10.1016/j.apt.2013.03.008},
   issn={09218831},
