}
@article{Bertolino2011,
   abstract={This paper presents a study of the mechanical properties of pseudoelastic Cu-Zn-Al foams. Foams of different densities were cycled in compression. The paper shows the retained/dissipated energy by the material, i.e. the area of the compression cycle, as a function of the material density. The frequency and strain amplitude, usual parameters that may influence the damping properties, are studied by evaluating the dissipated energy and the specific damping capacity. Samples cyclically tested under constrained compression conditions show a remarkable mechanical stability and reproducibility. The material does not appreciably degrade after 1000 compression cycles at room temperature. We emphasize the material does not need any thermomechanical processing or training treatment in order to present the mechanical properties detailed in the present paper. © 2010 Elsevier Ltd. All rights reserved.},
   author={G. Bertolino and A. Gruttadauria and P. Arneodo Larochette and E. M. Castrodeza and A. Baruj and H. E. Troiani},
