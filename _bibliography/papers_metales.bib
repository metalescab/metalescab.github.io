   volume={72},
   url={http://ecst.ecsdl.org/cgi/doi/10.1149/07207.0215ecst},
   year={2016},
}
@article{Garces2016,
   abstract={This work discusses the effect of the crystal structure and microstructure on the electrocatalytic activity of Lanthanum-Barium cobaltite (LBC), evaluatedas IT-SOFC cathode. Two systems with similar microstructures (particle sizes dp ≈ 1–5 μm) are used to compare the effect of the crystal structure: the cubic La0.5Ba0.5CoO3-δ with La/Ba cations randomly distributed, and a tetragonal LaBaCo2O6-δ with La/Ba layered distribution. In addition, the effect of microstructure is studied by using a newsol-gel route which allows obtaining LaBaCo2O6-δ with smallest particle size (dp ≈ 500 nm). The electrode reaction isstudied by electrochemical impedance spectroscopy (EIS) as a function of temperature (T) and oxygen partial pressure (pO2). The electrode polarization resistance (RC,P) presents two contributions, a low frequency (RLF) and a high frequency Gerischer-resistance (RG). On one side, RLF, associated to the O2-gas diffusion across the gas layer boundary, presents low activation energy (Ea) and is proportional to pO2−1, presenting the same values regardless the microstructure.On the other side, RG is in agreement with anO2-reduction mechanismco-limited by O-surface exchange and O-bulk diffusion. RG is strongly influenced by structure (trough the diffusion coefficient DV) and microstructure (inversely proportional to dp). Besides, RG decreases by reducing dp and by modifying the La/Ba ordering from layered to randomly distributed.},
   author={Diana Garcés and Analia L. Soldati and Horacio Troiani and Alejandra Montenegro-Hernández and Alberto Caneiro and Liliana V. Mogni},
   doi={10.1016/j.electacta.2016.08.132},
   isbn={9789048126637},
   issn={00134686},
   journal={Electrochimica Acta},
   keywords={IT-SOFC,LBC,O2-reduction reaction,cathode,perovskite},
   month={10},
   pages={637-646},
   publisher={Elsevier Ltd},
   title={La/Ba-based cobaltites as IT-SOFC cathodes: a discussion about the effect of crystal structure and microstructure on the O2-reduction reaction},
   volume={215},
   url={http://dx.doi.org/10.1016/j.electacta.2016.08.132 http://linkinghub.elsevier.com/retrieve/pii/S0013468616318679},
   year={2016},
}
