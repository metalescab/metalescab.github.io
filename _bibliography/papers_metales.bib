@article{Ahlers1992,
   abstract={The stability between the close packed martensitic structures 6R, 18R and 2H in CuZnAl single crystals is analysed. Experimental results for high electron concentrations (e/a > 1.50) and data from the literature for lower e/a are used, covering a wide range of compositions. Numerical values for the stacking fault energies and the differences of enthalpy are reported. The thermodynamic stability of the orthorhombic 18R structure with respect to 6R and 2H in a wide composition range is established. Nous analysons la stabilité entre les structures martensitiques compactes 6R, 18R et 2H dans des monocristaux de CuZnAl, à partir de nos résultats expérimentaux pour des concentrations électroniques élevées (e/a > 1,50), et de résultats publiés pour des valuers de c/a plus faibles, ce qui couvre un vaste domaine de compositions. Nous rapportons des valeurs numériques d'énergies de faute d'empilement et de différences d'enthalpie. Nous établissons enfin la stabilité thermodynamique de la structure orthorhombique 18R par rapport aux structures 6R et 2H dans un grand domaine de compositions. Die Phasenstabilität zwischen den dichtest gepackten 6R, 18R und 2H Martensitstrukturen in CuZnAl Einkristallen wird beschrieben. Experimentelle Ergebnisse bei hohen Elektronenkonzentrationen (e/a > 1.50) und Literaturdaten bei niedrigeren e/a werden benutzt, um numerische Werte für die Stapelfehlerenergie und Enthalpiedifferenzen in einem groβen Konzentrationsbereich abzuleiten. Daraus wird gefolgert, daβ die orthorhombische 18R Struktur in einem weiten Zusammensetzungsbereich thermodynamisch stabiler ist als 6R und 2H.},
   author={M. Ahlers and J.L. Pelegrina},
   doi={10.1016/0956-7151(92)90034-C},
   issn={0956-7151},
   issue={12},
   journal={Acta Metallurgica et Materialia},
   month={12},
   pages={3213-3220},
   publisher={Pergamon},
   title={The martensitic phases and their stability in CuZn and CuZnAl alloys—II. The transformation between the close packed martensitic phases},
   volume={40},
   url={https://www.sciencedirect.com/science/article/pii/095671519290034C},
