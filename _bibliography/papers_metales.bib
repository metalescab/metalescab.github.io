@article{Lovey1989,
   abstract={Dislocations are observed in many shape memory alloys after thermal or stress cycling. The amount of dislocations (with Burgers vector bβ=a0〈010〉 and 〈1̄11〉 line direction in the β phase) increases with the number of cycles. The dislocations are accumulated in the sample and are incorporated in the corresponding growing phase. The relative energy of the dislocations when embedded in the parent phase or in one or another variant of martensite is evaluated in this work. The crystallographic changes of the dislocations provide a primary selection rule for those martensite variants in which the dislocations have the lowest energy. In order to proceed more quantitatively a full calculation of the dislocation energies has to be performed using the anisotropic theory. In this work these calculations have been made on the basis of measured elastic constants of the β and 2H phases of a Cu-Al-Ni alloy. It is found that a given dislocation could indeed have different energies depending whether it is embedded in the β phase or one or another oriented variant of martensite. In particular, those dislocations with Burgers vector lying on the basal plane of the 2H martensite show the lowest energy as compared to their self energy when embedded in other oriented variants (Burgers vector out of the basal plane) or in the β phase. On observe des dislocations dans de nombreux alliages à mémoire de forme soumis à des cycles thermiques ou à des cycles de contrainte. Le nombre de dislocations (de vecteur de Burgers bβ=a0 〈010〉 et de direction 〈111〉 dans la phase β) augmente avec le nombre de cycles. Les dislocations s'accumulent dans l'échantillon et sont incorporées dans la phase qui se développe. On évalue l'énergie relative des dislocations bloquées dans la phase mère ou installées dans l'une des variantes de la martensite. Les modifications cristallographiques des dislocations fournissent une règle de sélection primaire pour les variantes martensitiques dans lesquelles les dislocations ont l'énergie minimale. Si l'on désire des règles plus quantitatives, il est nécessaire d'effectuer un calcul complet de l'énergie des dislocations dans le cadre de la théorie anisotrope. Dans cette étude, nous avons réalisé ces calculus à partir des constantes élastiques mesurées des phases β et 2H d'un alliage Cu-Al-Ni. Une dislocation donnée pourrait en effet avoir des énergies différentes suivant qu'elle est placée dans la phase β ou dans l'une ou l'autre des variantes orientées de la martensite. En particulier, les dislocations dont le vecteur de Burgers est parallèle au plan de base de la martensite 2H présentent l'énergie la plus basse par rapport à leur énergie propre, lorsqu'elles sont placées dans d'autres variantes orientées (vecteur de Burgers hors du plan de base) on dans la phase β. In vielen Formgedächtnislegierungen werden Versetzungen nach thermischer oder mechanischer zyklischer Belastung beobachtet. Die Dichte der Versetzungen (Burgersvektor b̄β=a0 〈010〉 und Linienrichtung 〈111〉 in der β -Phase) nimmt mit der Zahl der Zyklen zu. Die Versetzungen häufen sich in der Probe an und werden in die entsprechenden wachsenden Phasen eingebaut. In dieser Arbeit werden die relativen Energien der in der Mutterphase oder in der einen oder anderen Martensitvariante eingebauten Versetzungen ermittelt. Die kristallografischen änderungen der Versetzungen liefern eine erste Auswahlregel für diejenigen Martensitvarianten, in denen die Versetzungen die niedrigste Energie haben. Für eine bessere Quantifizierung muβ eine vollständige Berechnung der Versetzungsenergien im Rahmen der anisotropen Elastizitätstheorie durchgeführt werden. Hier werden solche Rechnungen auf der Grundlage der gemessenen elastischen Konstanten der β- und der 2H-Phasen der Cu-Al-Ni-Legierung durchgeführt. Es ergibt sich, daβ eine gegebene Versetzung tatsächlich unterschiedliche Energien aufweisen kann, wenn sie in der β-Phase oder einer der orientierten Martensitvarianten liegt. Insbesondere haben die Versetzungen, deren Burgersvektor in der Basisebene des 2H-Martensits liegen, die niedrigste Energie im Vergleich zu ihrer Energie in den anderen orientierten Varianten (mit dem Burgersvektor dann aus der Basisebene herausschauend) oder in der β-Phase.},
   author={F.C Lovey and A Hazarabedian and J.E Garces},
   doi={10.1016/0001-6160(89)90029-1},
   issn={0001-6160},
   issue={9},
   journal={Acta Metallurgica},
   month={9},
   pages={2321-2327},
   publisher={Pergamon},
   title={The relative stability of dislocations embedded in the β phase matrix and in martensite phases in copper based alloys},
   volume={37},
   url={https://www.sciencedirect.com/science/article/pii/0001616089900291},
   year={1989},
}
@book{Guillermet1989c,
   abstract={A thermodynamic description of the Co-Fe-Ni-W-C system has been constructed by applyin the CALPHAD approach, which involves combination of available descriptions for the lower-order systems with evaluation or estiamtion of new higher-order parameters. A survey of these models, the thermodynamic parameters, and the sources of information on the lower-order systems is given. The present description may be used in discussions of the behavior of specific alloys. In particular, we use the description for gaining insight on the effects of substitutions of Co by Fe and Ni in the binder phase of Co-Fe-Ni bonded cemented WC tools.},
   author={Armando Guillermet},
   journal={Zeitschrift für Metallkunde},
   month={2},
