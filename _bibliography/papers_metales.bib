   year={1998},
}
@inproceedings{Condo1998,
   abstract={A detailed study of the non-basal plane (NBP) faults in 18R martensite in Cu-Zn-Al alloys has been performed, using transmission electron microscopy (TRIM). Four types of NBP faults are possible in the 18R martensite [l]. This set reduces to F, and F, after convenient atomic relaxations, producing six types of imperfect dislocations depending on the type of basal plane fault finishing at the NBP fault. The Burgers vectors of all these dislocations have been determined from the analysis of the images. All the relaxations are consistent with the conservation of the volume per atom at the NBP faults.},
   author={A M Condo and F C Lovey},
   city={Cancún, México},
   editor={H.A. Calderón Benavides and M.J. Yacamán},
   journal={Proceedings 14th International Conference on electron microscopy},
