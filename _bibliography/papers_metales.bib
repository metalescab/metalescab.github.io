@article{Romero1999,
   abstract={The critical stress to induce martensite in Cu-Zn and Cu-Zn-AI single crystals has been determined down to 80 K. It has been found that the stress increases linearly with increasing temperature. From this result it is deduced that the higher vibrational entropy of the P-phase compared with the martensite is due solely to the soft transverse [ EEO] phonon modes, the other modes remaining largely unaffected by the transformation. This result is consistent with the predictions of Zener on the stability of P-phases in the noble-metal alloys. The linearity in the temperature dependence of the critical stress has been used to obtain transformation temperatures by a linear extrapolation to zero stress. The results for alloys with Zn concentrations between 40 and 43 at.% Zn can be expressed as M, (K)=2686 - 64Czn. This dependence is different from what has been reported in the literature before. Finally, the influences of previous plastic deformation in the /3-phase and of a stressinduced transformation of the martensite to the FCT phase are considered.},
   author={R Romero and M Ahlers},
   doi={10.1088/0953-8984/1/20/002},
   issn={0953-8984},
   issue={20},
   journal={Journal of Physics: Condensed Matter},
   pages={3191-3200},
   title={On the martensitic transformation temperature and its stress dependence in Cu-Zn and Cu-Zn-Al single crystals},
   volume={1},
   year={1999},
}
