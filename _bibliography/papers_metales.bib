   year={1989},
}
@article{Guillermet1989,
   abstract={The consistency of the available thermodynamic information on the FeCoNi system (i.e. experiments of various kinds and available descriptions of the binary systems CoFe,CoNi and FeNi) has been analysed. The analysis is made by examining the experimental data in the light of a CALPHAD type of prediction of the ternary properties, based on combining the binary descriptions. Extensive comparisons between predictions and experiments are presented, which give the impression of a general compatibility. Various discrepancies are, however, revealed by the present analysis, which should be of importance for the design of new experimental studies of the ternary system, and the refinement of the binary descriptions.},
