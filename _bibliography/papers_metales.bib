   keywords={chemical synthesis,elasticity,magnetically ordered materials,magnetostriction,scanning microscopy},
   month={9},
   pages={44-46},
   publisher={Elsevier},
   title={Magnetic field dependence of elastic modulus and resistance in La2/3Ca1/3MnO3},
   volume={310},
   url={https://www.sciencedirect.com/science/article/pii/S0925838800009865},
   year={2000},
}
