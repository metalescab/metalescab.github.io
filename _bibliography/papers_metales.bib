   year={1991},
}
@article{CESARI1991,
   abstract={The two-way shape memory effect (TWSME) induced by pseudoelastic cycling in Cu-Zn-Al single crystals has been studied. We analyzed the influence of the mechanical cycling characteristics (tensile or compressing) and of the presence of [MATH]-phase precipitates in the material. The two-way memory effect induced by compressing cycling appears after a smaller number of cycles than in tensile pseudoelastic cycling. The presence of [MATH]-phase precipitates also reduces the number of cycles needed to get the TWSME. Samples with TWSME are able to overcome some external stress when going to the martensitic shape until a threshold stress, [MATH], value is reached. When higher opposing stresses are applied, the degradation of TWSME starts.},
   author={E. CESARI and C. PICORNELL and J. PONS and M. SADE},
