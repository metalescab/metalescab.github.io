@book{Guillermet1990,
   abstract={Theoretical calculations of phase diagrams, such as the standard CALPHAD approach, requre knowledge of the Gibbs energy G(T). Usually G(T) is taken from experiments. Recent work by the authors has revealed significant regularities in the strength of bonding with varying numbers of valence electrons in 3d-transition metal compounds. This allows an estimation of the vibrational part of G(T), to be used when experimental data are lacking. These findings are briefly reviewed. As an illustrative application, the authors consider in detail the phase stability of the carbide 'CrC', with the NaCl structure. They discuss in detail the estimation of its Gibbs energy, and the case where it is predicted as close to becoming stable as a high-temperature phase.},
   author={Armando Guillermet},
   journal={Zeitschrift für Metallkunde},
   month={7},
   pages={521-524},
   title={Correlations for Bonding Properties and Vibrational Entropy in 3d-Transition Metal Compounds, with Application to the CALPHAD Treatment of a Metastable Cr-C Phase},
   volume={81},
   year={1990},
}
@article{Planes1990,
   abstract={We study the contribution of the L21 long range ordered structure on the Ms temperature of Cu-Zn-Al alloys. Measuring the resolved shear stress required to induced the transformation in alloys with sufficiently low TL21 ordering temperature shows that it is possible to supperss the B2-L21 ordering transition by a rapid quench from temperatures Tq above but close to TL21. An analysis of the experimental results in terms of a simple model shows that the contribution of the L21 structure on the Ms temperature behaves linearly with (2xCu - 1)2 for the alloys considered. Finally we propose an emperical expression giving the Ms temperature of CuZnAl alloys as a function of composition. The expression is an extension of one proposed recently for CuZn binary alloys. We show that for ternary alloys with only B2 ordering. 1 at.% A1 has the effect of (96/64) at.% of Zn, while this effect reduces to (90.64) at.% when the alloy develops the L21 superlattice. Nous présentons une étude de la contribution de la structure ordonnée à longue distance L21 sur la température Ms d'alliages CuZnAl. La mesure de la tension nécessaire pour induire la transformation martensitique dans le cas d'alliages avec une température d'ordre TL21 suffisament basse, permet de montrer qu'il est possible de supprimer la transition B2-L21 par tempre rapide depuis des températures Tq supérieures mais proches à Tq. L'analyse des résultats expérimentaux à partir d'un modéle simple permet de montrer que la contribution de la structure L21 sur la température Ms présente, pour les alliages considérés, une dépendence linéare avec (2xCu - 1)2. Finallement nous proposons une expression empirique donnant la température Ms d'alliages CuZnAl en fonction de la composition. Cette expression est obtenue comme une extension de celle qui a étée proposée récemment pour lálliage binaire CuZn. Nous montrons que pour l'alliage ternaire avec seulement ordre type B2, 1 at.% d'aluminium a l'effet de (96/64) at.% de Zn, tandis que cet effet est réduit à (90/64) at.% quand le systéme developpe la structure L21. Wir untersuchen den Beitrag der ferngeordenetn L21-Struktur auf die Ms-Temperatur der CuZnAl-Legierungen. Messungen der für die Einleitung der Umwandlung nötigen Scherspannung an Legierungen mit genügend niedriger TL21-Ordnungseinstellungstemperatur zeigen, daβ es möglich ist, die Ordnungseinsstellung B2-L21 mit schnellen Abschrecken von Temperaturen Tq oberhalb von, aber nahe an TL21 zu unterdrüchen. Die Analyse der experimentellen Ergenbnisse mit einem einfachen Modell zeigt, daβ der Beitrag der L21-Struktur zur Ms-Temperatur bei den betrachteten Legierungen linear mit (2xCu - 1)2 verläuft. Zum Schluβ schlagen wir einen empirischen Ausdruck von, der Ms-Temperatur in Abhängigkeit von der Zusammensetzung der CuZnAl-Legeirungen deschreibt. Dieser Ausdruck ist eine Erweiterung eines kürzlich für binäre CuZn Legierungen vorgeschlagene Ausdrucks. Wir zeigen, daβ bei ternären Legierungen mit nur der B2-Ordnung 1 At.-% A1 den Einfluβ von (96/64) At.% Zn hat, wohingegen dieser Einfluβ sich auf (90/64) At.-% verringert, wenn die Legierung das L21-Übergitter entwickelt.},
   author={A. Planes and R. Romero and M. Ahlers},
   doi={10.1016/0956-7151(90)90027-E},
   issn={0956-7151},
   issue={5},
   journal={Acta Metallurgica et Materialia},
   month={5},
   pages={757-763},
   publisher={Pergamon},
   title={The martensitic transition temperature in ternary Cu-Zn-Al alloys. Influence of the L21 structure},
   volume={38},
   url={https://www.sciencedirect.com/science/article/pii/095671519090027E},
   year={1990},
}
@article{Kikuchi1990,
   abstract={The mechanism of formation of the Widmanstätten plates which have recently been found in chromium-rich CrNi alloys, and are quite similar to the typical “Bainitic” plates in copper and silver based alloys, is discussed here by combining experimental data on the composition ofthe Widmanstätten plate with thermodynamic calculations of the stable and metastable phase equilibria. The observed nickel concentration of the Widmanstätten plate is about 30 mass% higher than that of the original b.c.c. (α) matrix, but it is about 4 mass% smaller than that of the f.c.c. (γ) phase in equilibrium with the b.c.c. phase at the start of the plate formation. The possibility of plate-formation mechanisms based on martensitic transformations from b.c.c. or to f.c.c. or from b.c.c. to a metastable phase with the so-called 3R structure is unambiguously excluded from thermodynamic considerations. The precipitation of the metastable phase with the 3R structure is proposed as the most probable mechanism of Widmanstätten plate formation. This mechanism explains the composition of the plate as well as the temperature range and the region of alloy compositions, where the Widmanstätten plate formation has been observed. Nous discutons dans cet article le mécanisme de formation des plaquettes de Widmanstätten qui ont été observées récemment dans des alliages NiCr riches en chrome, et qui sont tout à fait semblables aux plaquettes “bainitiques” typiques dans les alliages à base de cuivre ou d'argent. Cette discussion combine à la fois des résultats expérimentaux sur la composition des plaquettes de Widmanstätten, et des calculs thermodynamiques sur les équilibres de phases stables et métastables. La concentration expérimentale en nickel de la plaquette de Widmanstätten est d'environ 30% (en masse) supérieure à celle de la la matrice c.c. (α) de départ, mais elle est 4% environ inférieure à celle de la phase c.f.c. (γ) qui est en équilibre avec la phase c.c. au début de la formation de la plaquette. Des considerations thermodynamiques permettent d'éliminer sans ambiguïté la possibilité des mécanismes de formation des plaquettes basés sur des transformations martensitiques c.c.→c.f.c., ou c.c.→ phase métastable de structure 3R. Nous proposons comme mécanisme de formation le plus probable la précipitation de cette phase métastable de structure 3R. Ce mécanisme explique la composition de la plaquette ainsi que la gamme de températures et le domaine de composition des alliages où l'on observe la formation des plaquettes de Widmanstätten. Die Bildungsmechanismen der vor kurzem in Cr-reichen CrNi-Legierungen gefundenen Widmannstätten-Platten werden hier untersucht. Diese Platten ähneln den typischen “Bainit”-Platten in Legierungen auf Kupfer- und Silber-Basis sehr. Zur Untersuchung werden experimentelle Bestimmungen der Zusammensetzung der Platten mit thermodynamischen Berechnungen der stabilen und metastabilen Phasengleichgewichte kombiniert. Die beobachtete Nickelknozentration der Widmannstätten-Platten liegt etwa 30 Massen-% höher als in der ursprünglichen krz. (α-) Matrix, ist aver etwa 4 Massen-% niedriger als in der kfx. (γ-) Phase, die zu Beginn der Plattenbildung mit der krz. Phase im Gleichgewicht steht. Die Möglichkeit, daβ sich die Platten über einen Mechanismus bilden, der auf martensitischen Umwandlungen von krz. zu kfz. oder von krz. zu einer metastabilen Phase mit der sogenannten 3R-Struktur beruht, wird aus thermodynamischen überlegungen heraus eindeutig ausgeschlossen. Als wahrscheinlichster Prozeβ der Bildung der Widmannstätten-Platten wird die Ausscheidung der metastabilen Phase mit der 3R-Struktur angesehen. Dieser Mechanismus erklärt die Zusammensetzung der Platte wie auch den Temperaturbereich und den Bereich der Legierungszusammensetzung, in denen die Bildung der Widmannstätten-Platten beobachtet worden ist.},
   author={M. Kikuchi and A. Fernandez Guillermet and M. Hillert and G. Cliff and G.W. Lorimer},
   doi={10.1016/0956-7151(90)90045-I},
   issn={0956-7151},
   issue={2},
   journal={Acta Metallurgica et Materialia},
   month={2},
   pages={165-171},
   publisher={Pergamon},
   title={Mechanism of Widmanstätten plate formation in chromium-rich CrNi alloys},
   volume={38},
   url={https://www.sciencedirect.com/science/article/pii/095671519090045I},
   year={1990},
}
