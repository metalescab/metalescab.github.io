@article{CastroRiglos2018,
   abstract={The combined effect of micro-alloying with Si and Ge and/or plastic deformation prior to ageing at 160˚C on age hardening has been studied in an Al-2 at% Cu alloy. The results obtained indicate that the hardness response is faster and the peak hardness is higher when plastic deformation and micro-alloying are applied together than performing each procedure individually. Different amounts of deformation, ranging from 0% to 30% have been utilized. An optimum deformation degree for the hardening response has been established around 8% for the Al-Cu-Si-Ge alloy. Characterization by transmission electron microscopy (TEM) shows that the peak hardness is due to a complex microstructure that contained  disc shaped precipitates, rod-shaped Si-Ge precipitates and  plates that were heterogeneously nucleated on the Si-Ge particles. Pre-deformation has been found to stimulate the growth of the  plates due to enhanced diffusion along dislocation cores. Increasing deformation reduces the influence of the Si-Ge precipitates on heterogeneous nucleation, leading to reduced peak hardness and faster over-ageing.},
   author={Maria Victoria Castro Riglos and Alfredo Tolley},
   doi={10.4236/jmmce.2018.63025},
   issn={2327-4077},
   issue={03},
   journal={Journal of Minerals and Materials Characterization and Engineering},
   keywords={Al-Cu Based Alloys, Precipitation, Microstructure,},
   pages={356-372},
   title={Influence of Si and Ge Microalloying Additions and Plastic Deformation on Precipitation Processes in Al-Cu Based Alloys},
   volume={06},
   year={2018},
}
@article{Marinelli2001b,
   abstract={The lattice parameters of the hexagonal close-packed (HCP) phase have been investigated as a function of the composition, using an X-ray technique. With the present results, reliable trends in the composition dependence of the axes a and c are established, which are significantly simpler than those suggested by early measurements. In addition, new extrapolations to 0 at.% Mn are performed, which are compared with other indirect information on the HCP phase of Fe at room temperature and atmospheric pressure. Finally, by combining the present measurements on the HCP phase with those on the face-centred cubic (FCC) phase reported in the first paper of this series, a detailed analysis is made of the changes in the interatomic distances as well as the relative volume change associated with the FCCHCP martensitic transformation. According to the present results such volume change is essentially independent of the Mn content, which should be interesting in modelling the energetics of the FCCHCP transformation},
   author={P. Marinelli and A. Baruj and A.F. Guillermet and M. Sade},
   issn={0044-3093},
   issue={May 2001},
   journal={Zeitschrift fur Metallkunde},
   keywords={fe-base alloys,fe-mn system,lattice parameters of fe-,mar-,mn alloys,tensitic transformation},
   pages={489-93},
   title={Lattice parameters of metastable structures in quenched Fe-Mn alloys. II. HCP phase},
   volume={92},
   year={2001},
}
@article{Sommadossi2007c,
   abstract={In this work preliminary results are reported on the characterization of Pb-free joints produced by using a diffusion soldering method at a process temperature of 700 &deg;C during 20 min. The solder alloy is a metallic paste involving Ga and Al and Ni powder, and the substrates are Cu and Ni. The dissolution and diffusion-reaction processes, which take place at the interfaces of the interconnection zone, have been investigated by means of SEM and EPMA. A solid solution and intermetallic compounds (IMCs) with high melting point form as layers almost free from defect, allowing service temperatures about 500 &deg;C higher than the process temperature. The phase stability sequence starting from the Ni to the Cu interface is the following: &alpha;&prime;- Ni<inf>3</inf>Ga, &gamma;-Cu<inf>9</inf>Ga<inf>4</inf>, &beta;-Cu<inf>3</inf>Ga and (Cu) solid solution of the Ga-Cu system. The relative reaction front displacement of the layers and the implications of the present findings for the applicability of the diffusion-soldering method are also discussed. &copy; 2007 Springer Science+Business Media, LLC.},
   author={Silvana Sommadossi and Horacio E. Troiani and Armando Fernández Guillermet},
   doi={10.1007/s10853-007-1940-z},
   issn={00222461},
   issue={23},
   journal={Journal of Materials Science},
   pages={9707-9712},
   title={Diffusion soldering using a Gallium metallic paste as solder alloy: Study of the phase formation systematics},
   volume={42},
   year={2007},
}
