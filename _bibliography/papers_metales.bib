@article{Pelegrina1992,
   abstract={The stability between the high temperature β phase and the orthorhombic martensite in CuZn and CuZnAl single crystals is analyzed. Experimental results for high electron concentrations (e/a > 1.50) and data from the literature for lower e/a are used, covering a wide range of compositions. Numerical values for the differences of entropy and enthalpy are reported. Also, the contribution of L21 order to the phase stability is evaluated and an estimation of pair interchange energies is obtained. Nous analysons la stabilité entre la phase β de haute température et la martensite orthorhombique dans des monocristaux de CuZn et de CuZnAl, à partir de nos propres résultats expérimentaux obtenus pour des concentrations électroniques élevées (e/a > 1,50), ainsi que de résultats publiés pour des valeurs de e/a plus faibles, ce qui couvre un vaste domaine de compositions. Nous rapportons des valeurs numériques des différences d'entropie et d'enthalpie. Nous évaluons également la contribution de l'ordre L21 à la stabilité des phases, et nous estimons les énergies d'échange des paires. Die Phasenstabilität zwischen der Hochtemperatur β-Phase und dem orthorhombischen Martensit in CuZn und CuZnAl Einkristallen wurde untersucht. Experimentelle Ergebnisse für hohe Elektronenkonzentrationen (e/a > 1.50) und Literaturdaten für niedrigere e/a wurden ausgewertet, um einen möglichst grossen Zusammensetzungsbereich zu überstreichen. Numerische Werte für die Entropie- und Enthalpieunterschiede werden berichtet. Ausserdem wurde der Einfluss der L21 Ordnung auf die Phasenstabilität analysiert, und eine Abschätzung der Paarwechselwirkungsenergien gegeben.},
   author={J.L. Pelegrina and M. Ahlers},
   doi={10.1016/0956-7151(92)90033-B},
   issn={0956-7151},
   issue={12},
   journal={Acta Metallurgica et Materialia},
   month={12},
   pages={3205-3211},
   publisher={Pergamon},
   title={The martensitic phases and their stability in CuZn and CuZnAl alloys—I. The transformation between the high temperature β phase and the 18R martensite},
   volume={40},
   url={https://www.sciencedirect.com/science/article/pii/095671519290033B},
   year={1992},
}
@article{Saule1992,
   abstract={The lattice parameters have been measured for 6R, 18R and 2H CuZnAl martensites. Whereas 6R is nearly cubic f.c.c., the 18R and 2H are strongly distorted. The relationship between the MS temperature and the distortion is the same for stabilized and nonstabilized martensite. On the basis of the experimental results the stabilities of the different phases are discussed. The enthalpy differences between disordered f.c.c. and b.c.c. agree well with first principle calculations. The lattice distortion leads to an increase in the stability of 18R, and to a reduction of the composition dependence of MS. Nous avons mesuré les paramètres réticulaires des martensites CuZnAl 6R, 18R et 2H. Alors que la structure 6R est pratiquement c.f.c., les structures 18R et 2H sont très distordues. La relation entre la température MS et la distorsion est la même pour la martensite stabilisée et pour la martensite non stabilisée. Nous discutons la stabilité des différentes phases à partir de nos résultats expérimentaux. Les différences d'enthalpie entre la structure c.f.c. désordonnée et la structure c.c. sont en bon accord avec des calculs fondamentaux. La distorsion du réseau conduit à un accroissement de la stabilité de la structure 18R, et à une réduction de l'effet de la composition sur MS. Die Gitterkonstanten wurden für 6R, 18R und 2H Martensit in CuZnAl Legierungen gemessen. Während 6R fast kubisch flächenzentriert ist, sind 18R und 2H stark verzerrt. Die Beziehung zwischen MS Temperatur und Gitterverzerung ist dieselbe für stabilisierten und nichtstabilisierten Martensit. Basierend auf den experimentellen Ergebnissen werden die Stabilitäten der verschiedenen Phasen diskutiert. Die Enthalpieunterschiede zwischen ungeordneten f.c.c. und b.c.c. stimmen gut mit ab initio Berechnungen überein. Die Gitterverzerrungen bewirken eine zusätzliche Stabilität des 18R Martensits und eine Verringerung der Konzentrationsabhängigkeit von MS.},
   author={F. Saule and M. Ahlers and F. Kropff and E.B. Rivero},
   doi={10.1016/0956-7151(92)90036-E},
   issn={0956-7151},
   issue={12},
   journal={Acta Metallurgica et Materialia},
   month={12},
   pages={3229-3238},
   publisher={Pergamon},
   title={The martensitic phases and their stability in CuZn and CuZnAl alloys—IV. The influence of lattice parameter changes and evaluation of phase stabilities},
   volume={40},
   url={https://www.sciencedirect.com/science/article/pii/095671519290036E},
   year={1992},
}
@article{Aligia1992,
   abstract={We study the ground state and weakly excited oxygen superstructures of RBA2Cu3O6+x, where R=Y or a rare earth, using a model lattice gas Hamiltonian introduced earlier by the authors. This model assumes that any two O ions of the CuOx planes repel each other with a screened Coulomb interaction, but the repulsion between second-neighbour O ions with a Cu ion in between is reduced by a factor f. The value of f was calculated using the extended Hubbard Hamiltonian in the strong-coupling limit. For large screening length λ, R=Y and x=38 the predictions of the model are in excellent agreement with recent neutron measurements. Assuming that λ decreases strongly in the metallic phase, all previously observed diffraction patterns for R=Y can also be explained (x=18, 12, 47, 35, 58, 23, 34 and 78). We conclude that CuO chains can be observed almost exclusively in the metallic phase and predict superstructures that should be observed in semiconducting materials, in particular when x≥12 and the ionic radius of R3+ is larger than that of Y3+.},
   author={A.A. Aligia and J. Garcés and H. Bonadeo},
   doi={10.1016/0921-4534(92)90601-8},
   issn={0921-4534},
   issue={3},
   journal={Physica C: Superconductivity},
   month={1},
   pages={234-248},
   publisher={North-Holland},
   title={Oxygen superstructures in semiconducting RBa2Cu3O6+x},
   volume={190},
   url={https://www.sciencedirect.com/science/article/pii/0921453492906018},
   year={1992},
}
@article{Fernandez-Guillermet1992,
   abstract={Thermodynamic properties of the Co-N system are poorly known from experiments, and there is a need of information on the stability of its various phases and the phase diagram This kind of information has been obtained by us Our approach combines the methods of thermodynamic modelling developed in the so-called CALPHAD ie CALculation of PHase Diagrams) work with predictions of unknown thermodynamic quantities The predictions of entropy and enthalpy of formation for nitrides are based on regularities in bonding properties and vibrational entropy of 3d-transition metal compounds The excess Gibbs energy parameters for the cubic and hexagonal nitride phase are determined by interpolation, relying on trends in the data for 3d-transition metal-nitrogen systems The properties of the liquid phase are evaluated from experiments and tested in calculations of N-solubility in the ternary systems Co-Cr-N, Co-Fe-N and Co-Ni-N The Gibbs energy functions obtained by us are used as input information in the Hillert-Staffansson ''Two-Sublattice'' phenomenological model to calculate the Co-N phase diagram Our results are compared with information on the Fe-N and Ni-N systems, and with the predictions of Miedema's formula (orig)},
   author={A Fernandez-Guillermet and S Jonsson},
   city={Germany},
   issn={0044-3093},
   issue={1},
   journal={Zeitschrift fuer Metallkunde},
   pages={21-31},
   title={Predictive approach to thermodynamic properties of Co nitrides and phase stability in the Co-N system},
   volume={83},
   url={http://inis.iaea.org/search/search.aspx?orig_q=RN:23034588},
   year={1992},
}
@article{FernandezGuillermet1992,
   abstract={We present a study of the cohesive energies (E(coh)) of all 4d-transition-metal carbides and nitrides in the NaCl-type structure using ab initio linear-muffin-tin-orbitals type total-energy calculations and an extensive analysis of thermodynamic data. Many of the carbides considered here are metastable and their cohesive energy is not known from direct measurements. In these cases, we estimate E(coh) using thermodynamic model calculations and analyses of phase diagrams. This information allows us to perform a detailed comparison of theoretical (E(coh)th) and thermodynamic (E(coh)e) cohesive energy values. The difference E(coh)th - E(coh)e is positive for all carbides and nitrides, and we discuss the various sources of error in the theoretical approach. Trends in theoretical E(coh) values are remarkably improved when spectroscopic data are used to correct calculated atomic total energies. We also show that most of the discrepancy between theoretical and thermodynamic results cancels in the difference DELTA-E(coh) between a carbide MC and a nitride MN of the same transition-metal M, and excellent agreement with experiments is obtained for the systems where thermodynamic information is available, viz., for M=Zr, Nb, and Mo. This fact allows us to estimate the unknown cohesive energies and enthalpies of formation for YN, TcN and for the metastable NaCl structures of RuN, RhN, and PdN, from a combination of ab initio results and assessed thermodynamic information for the corresponding carbides. Our method of theory-based predictions of thermodynamic quantities is compared with the semiempirical method of Miedema. We also discuss the role of extrapolation methods related to ab initio results in the estimation of thermodynamic information that is used in the modeling of alloy phase diagrams.},
   author={A. Fernández Guillermet and J. Häglund and G. Grimvall},
   doi={10.1103/PhysRevB.45.11557},
   isbn={0163-1829},
   issn={0163-1829},
   issue={20},
   journal={Physical Review B},
   month={5},
   pages={11557-11567},
   pmid={10001169},
   title={Cohesive properties of 4 d -transition-metal carbides and nitrides in the NaCl-type structure},
   volume={45},
   url={https://link.aps.org/doi/10.1103/PhysRevB.45.11557},
   year={1992},
}
@article{Guillermet1992,
   abstract={The thermodynamic properties of the Fe-Co-N system are poorly known from experiments and there is a need for information on the stability of its various phases, and the Fe-Co-N phase diagram This type of information has now been obtained The approach is based on the use of thermodynamic models and the construction of probable Gibbs energy (Gm) functions for the various phases in the system The model parameters originating in the Fe-Co, Fe-N and Co-N systems are taken from recent analyses, whereas the purely ternary Gm parameters are evaluated from experiments or are estimated The estimation methods for stoichiometric nitrides rely on regularities in bonding properties and vibrational entropy of 3d-transition metal compounds, and the estimations of excess Gibbs energy parameters make use of trends in the information for related systems The new results are presented in a table of thermodynamic parameters, ten calculated isothermal sections of the Fe-Co-N phase diagram for temperatures between 773 and 1673 K, the liquids surface and the calculated N solubility in solid and liquid Fe-Co alloys (orig)},
   author={A F Guillermet and S Jonsson},
   city={Germany},
   issn={0044-3093},
   issue={3},
   journal={Zeitschrift fuer Metallkunde},
   pages={165-175},
   title={Thermodynamic analysis of the Fe-Co-N system and predictive approach to the phase diagram},
