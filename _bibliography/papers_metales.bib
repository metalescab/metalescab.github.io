   year={2000},
}
@article{Benites2000d,
   abstract={This paper reports the results of a neutron diffraction study of a series of Zr-Nb alloys quenched from high temperatures, where bcc (beta) is the stable phase. Upon quenching, two additional structures are formed and retained metastably, viz. the hcp (alpha') phase, which forms through a martensitic transformation, and the omega (omega) phase, which forms by a displacive transformation involving the collapse of (111)(bcc) planes. The lattice parameters (LPs) of the beta, alpha' and omega phases are determined as functions of the Nb content in the composition interval 4 less than or equal to at.% Nb less than or equal to 31, which represents a significant expansion of the experimental database for these various metastable structures. With the present data, reliable trends in the composition dependence of the LPs are established. In general, a smooth, essentially linear dependence upon the Nb content is detected, corresponding to Vegard's law. However, a striking deviation from this simple behaviour is detected in the a(omega) parameter for Zr-rich alloys, i.e. in the region where this LP is directly related to the shortest interatomic distance (LD) in the omega phase. The need for a new analysis of the composition dependence of the various IDs in the omega phase is emphasized. (C) 2000 Elsevier Science S.A. All rights reserved.},
   author={G.M. M Benites and A. Fernández Guillermet and G.J. J Cuello and Javier Campo and A F Guillermet and G.J. J Cuello and Javier Campo},
   doi={10.1016/s0925-8388(99)00683-0},
   isbn={0925-8388},
   issn={09258388},
   issue={1-2},
   journal={Journal of Alloys and Compounds},
   keywords={bcc,crystal-structures,distances,lattice,metastable phases,omega phase,omega-phase,parameters,phase transformations,stability,system,zirconium niobium alloys},
   month={3},
   pages={183-188},
   publisher={Elsevier},
   title={Structural properties of metastable phases in Zr-Nb alloys I. Neutron diffraction study and analysis of lattice parameters},
   volume={299},
   url={https://www.sciencedirect.com/science/article/pii/S0925838899006830},
   year={2000},
}
