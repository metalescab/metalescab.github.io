@article{Salva1996b,
   abstract={We have measured anelastic properties of the Peierls transition over three samples of (TaSe4)2I containing different defect concentration (Tp=242.5 K and 255 K). We observed a huge change in the elastic shear modulus (ΔGG ∼ 12%) accompanied by a significant internal friction peak (ΔQ−1 ∼ 10−2) at 1 Hz. Due to the randomness of the calculated critical exponents we propose that the transition develops as a first order one, perpendicular to the chain direction.},
