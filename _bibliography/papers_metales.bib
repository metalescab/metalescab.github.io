@article{Pons1990,
   abstract={The arrangements of dislocations formed during thermally-induced martensitic transformation cycling in a CuZnAl single crystal have been analyzed by transmission electron microscopy. The dislocations were mainly of a mixed type, with bdu=<111>andb=<001>. Two thermal treatments prior to cycling have been considered, finding some differences in the dislocatios distributions and their evolution. These differences are well correlated with those found when studying the thermal cycling of the same alloy by means of calorimetry. Simple considerations show that the evolution of the macroscopic parameters (transformation temperatures, hysteresis cycle shape and position) can be explained semiquantitatively in terms of the free energy changes produced by: (a) the dislocations, when embedded in the ß or in the martensitic phases; (b) stacking faults created in martensite by some of the dislocations appearing during the cycling and (c) the increase in the area of martensite-martensite interfaces. On a analysé, par microscopie électronique à transmission, les distributions de dislocations formées dans un alliage CuZnAl monocristallin, pendant la répétition cyclique de la transformation martensitique induite par température. Les dislocations formées sont de type mixte, avec u=<111>et b=<001>. On a consideré deux traitements thermiques des échantillons avant le cyclage thermique, et quelques différences dans les distributions de dislocations et leur évolution ont été observées. Ces différences sont bien correlées avec celles montrées par l'étude calorimétrique du cyclage thermique sur le même alliage. Quelques considerations simples montrent que l'évolution des paramètres macroscopiques (températures de transformation, forme et position du cycle d'hystérésis) peut être expliquée semi-quantitativement si l'on tient en compte des changements dans l'énergie libre produits par: (a) les dislocations, quand elles sont dans la phase mère ß ou dans la phase martensitique; (b) lesdéfauts d'empilement créés en martensite par certaines dislocations qui apparaissent pendant le cyclage, et (c) la croissance du nombre d'interfaces martensite-martensite. Die Versetzungsanordnung, die sich während der zyklisch thermische induzierten martensitischen Umwandlung in einem CuZnAlEinkristall bildet, wird im Durchstrahlungselektronenmikroskop analysiert. Die Versetzungen sind meist vom gemischten Typ mit u=<111>und b=<001>. Zwei thermische Behandlungen vor den Temperaturwechseln werden verwendet, um Unterschiede in der Versetzungsverteilung und deren Entwicklung aufzufinden. Diese Unterschiede sind gut korreliert mit denjenigen, die kalorimetrisch bei der Untersuchung des Temperaturzyklens dderselben Legierung gefunden wurden. Einfache Argumente zeigen, daß die Entwicklung der makroskopischen Parameter (Umwandlungstemperatur, Form und Lage der Hystereseschleife) halbquantitativ erklärt werden kann anhand von Änderungen der freien Energie. Diese rühren her von (a) den Versetzungen, wenn sie in der ß-oder in der martensitischen Phase liegen, (b) den Stapelfehlern, die im Martensit von einigen während der Zyklens erscheinenden Versetzungen erzeugt werden und (c) der Zunahme der Fläche der Martensit-Martensit-Grenzen.},
   author={J. Pons and F.C. Lovey and E. Cesari},
   doi={10.1016/0956-7151(90)90287-Q},
   issn={0956-7151},
   issue={12},
   journal={Acta Metallurgica et Materialia},
   month={12},
   pages={2733-2740},
   publisher={Pergamon},
   title={Electron microscopy study of dislocations associated with thermal cycling in a CuZnAl shape memory alloy},
   volume={38},
   url={https://www.sciencedirect.com/science/article/pii/095671519090287Q},
   year={1990},
}
