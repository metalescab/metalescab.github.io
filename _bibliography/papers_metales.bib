}
@article{Guillermet1988,
   abstract={The thermodynamic properties of the Fe-Co-C system have been established by using a rather general Calphad technique, which involves a combination of predictions from assessed binary sides with computerized optimization of new, ternary, phenomenological parameters, and estimation of the stability of metastable phases. Comparisons between experiments and calculations are presented, and the accuracy of the predictions, or the goodness of fit to the ternary data, are discussed. The properties of the cementite and bcc phase in the Co-C have been estimated. The present description is used to analyse the early experimental results by Vogel and Sundermann. Most of their observations are satisfactorily accounted for, although some dicrepancies are noted. The need of a new experimental study of the solid/solid transformation temperatures in the Co-C rich side of the system is emphasized.},
   author={Armando Guillermet},
   journal={Zeitschrift für Metallkunde},
   month={5},
   pages={88-95},
   title={Thermodynamic Properties of the Fe-Co-C System},
   volume={79},
   year={1988},
}
