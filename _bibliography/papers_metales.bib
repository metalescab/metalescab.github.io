@article{Pelegrina1988,
   abstract={[100] Zone electron diffraction patterns from β′1-M18R CuZnAl martensite have been examined. Reflections forbidden by the structure factor are found to appear in this pattern. It is argued that an earlier structural model proposed by Delaey and Warlimont to account for similar reflections is inadequate. Instead, it is proposed that the reflections could appear by double diffraction via Higher Order Laue Zone reflections without requiring any changes in the M18R structure for the martensite. Nous avons étudié les diagrammes de diffraction électronique de la zone [100], obtenus dans la martensite CuZnAlβ′1. Des réflexions interdites par le facteur de structure apparaissent dans ces diagrammes. Nous démontrons qu'un modèle structural antérieur, proposé par Delaey et Warlimont pour expliquer des réflexions semblables, n'est pas correct. A la place, nous suggérons que ces réflexions pourraient apparaître par une double diffraction faisant intervenir des réflexions de zones de Laue d'ordre supérieur, sans qu'il soit besoin d'invoquer des modifications de la structure M18R de la martensite. Die Elektronenbeugungsdiagramme der [100]-Zone wurden in β′1-M18R CuZnAl untersucht. In diesen Diagrammen erscheinen Reflexe, die nach dem Strukturfaktor verboten sind. Es wird dargelegt, daß ein früher von Delaey und Warlimont zur Erklärung ähnlicher Reflexe vorgeschlagenes Modell nicht anwendbar ist. Stattdessen wird hier vorgeschlagen, daß die Reflexe als Folge von Doppelbegung über Reflexe aus Lauezonen höherer Ordnung auftreten könnten. Dieser Vorschlag hat den Vorteil, daß die M18R-Struktur des Martensits unverändert bleiben kann.},
   author={J.L. Pelegrina and M. Chandrasekaran and M.S. Andrade},
   doi={10.1016/0001-6160(88)90164-2},
   issn={0001-6160},
   issue={4},
   journal={Acta Metallurgica},
   month={4},
   pages={1111-1115},
   publisher={Pergamon},
   title={On the structural implication of some weak reflections in [100] zone electron diffraction patterns from β′1CuZnAl martensite},
   volume={36},
   url={https://www.sciencedirect.com/science/article/pii/0001616088901642},
   year={1988},
}
@article{Sade1988a,
   abstract={The effects of cycling through the complete temperature range on the subsequent transformation behaviour of FeMnSi alloys are explored. The alloys show the one-way shape memory effect related to the reversible fcc ( gamma )multhcp ( epsilon ) transformation that takes place with a thermal hysteresis of about 100 deg C. Thermal cycling lowers the start of martensitic transformation and increases the austenite start, that reduces the deformation inducing one-way shape memory effect.},
